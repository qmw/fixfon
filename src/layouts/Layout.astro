---
import "../styles/global.css";
interface Props { title?: string; description?: string; }
const { title = "FixFon — Serwis GSM Warszawa | Naprawa telefonów i tabletów", description = "FixFon to szybki serwis GSM w Warszawie. Naprawa ekranów, baterii, zalanych telefonów iPhone i Samsung. Gwarancja 12 miesięcy. Wycena online!" } = Astro.props;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,900&family=Space+Grotesk:wght@300;400;500;600;700&family=Roboto+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <a id="promo-bar" href="https://stronainternetowa.biz" target="_blank" rel="noopener">Przykładowa strona od <strong>stronainternetowa.biz</strong></a>
    <slot />
    <script>
      // Reveal on scroll
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal, .reveal-left, .reveal-right").forEach((el) => io.observe(el));

      // Nav scroll effect
      const nav = document.getElementById("nav");
      if (nav) {
        const onScroll = () => nav.classList.toggle("scrolled", window.scrollY > 40);
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // Mobile menu
      const burger = document.getElementById("burger");
      const mobileMenu = document.getElementById("mobile-menu");
      burger?.addEventListener("click", () => mobileMenu?.classList.toggle("hidden"));
      mobileMenu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => mobileMenu?.classList.add("hidden")));

      // Sticker calculator
      const calcForm = document.getElementById("calc-form");
      const calcResult = document.getElementById("calc-result");
      const calcDevice = document.getElementById("calc-device") as HTMLSelectElement | null;
      const calcService = document.getElementById("calc-service") as HTMLSelectElement | null;

      const prices: Record<string, Record<string, number>> = {
        "iphone-14": { "ekran": 799, "bateria": 299, "gniazdo": 349, "zalanie": 449 },
        "iphone-13": { "ekran": 699, "bateria": 249, "gniazdo": 299, "zalanie": 399 },
        "iphone-12": { "ekran": 549, "bateria": 199, "gniazdo": 279, "zalanie": 379 },
        "samsung-s24": { "ekran": 849, "bateria": 279, "gniazdo": 329, "zalanie": 449 },
        "samsung-s23": { "ekran": 749, "bateria": 249, "gniazdo": 299, "zalanie": 399 },
        "samsung-a54": { "ekran": 449, "bateria": 179, "gniazdo": 249, "zalanie": 349 },
        "inny": { "ekran": 299, "bateria": 149, "gniazdo": 199, "zalanie": 299 },
      };

      function updateCalc() {
        if (!calcDevice || !calcService || !calcResult) return;
        const dev = calcDevice.value;
        const svc = calcService.value;
        if (dev && svc && prices[dev] && prices[dev][svc]) {
          const p = prices[dev][svc];
          calcResult.textContent = `od ${p} zł`;
          calcResult.classList.remove("opacity-0");
          calcResult.classList.add("opacity-100");
        } else {
          calcResult.textContent = "—";
        }
      }

      calcDevice?.addEventListener("change", updateCalc);
      calcService?.addEventListener("change", updateCalc);
    </script>
  </body>
</html>
